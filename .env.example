# =========================================================================
# API Configuration for SLM Auto Config Pipeline
# =========================================================================

# --- OpenRouter API (Required for Node 2 Synthetic Data Generation) ---
# Used to call open source models via Distilabel 
OPENROUTER_API_KEY="sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxx"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# --- HuggingFace API (Optional but recommended for Node 4/5/7) ---
# Required if you're loading gated models (like Llama-3) or pushing your 
# final exported adapter to the HuggingFAce hub in Node 7.
HF_TOKEN="hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
